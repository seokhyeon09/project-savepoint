/* src/app/ProtectApp.css */

/* 전체 화면을 꽉 채우는 컨테이너 */
.dashboard-layout {
  display: flex;
  flex-direction: column;
  overflow: hidden; /* 전체 화면 단위의 스크롤 방지 */
}

/* 상단바 아래 영역 분할 (사이드바 + 메인) */
.dashboard-body {
  display: flex;
  flex: 1; /* 상단바를 제외한 남은 공간을 모두 차지 */
  overflow: hidden; 
}

/* 메인 콘텐츠 영역 (Outlet이 들어가는 곳) */
.dashboard-main {
  flex: 1; /* 사이드바를 제외한 우측 공간 모두 차지 */
  padding: 24px;
  overflow-y: auto; /* 콘텐츠가 많아지면 이 부분만 스크롤됨! */
}
</file>

